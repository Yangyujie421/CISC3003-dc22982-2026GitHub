PORT=3000
NODE_ENV=development
SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars
APP_URL=http://localhost:3000

# Email delivery
# Gmail App Password quick start:
# EMAIL_PROVIDER=gmail
# SMTP_USER=yourname@gmail.com
# SMTP_PASS=your-16-digit-app-password
# MAIL_FROM=Your Name <yourname@gmail.com>
#
# Custom SMTP quick start:
# EMAIL_PROVIDER=smtp
# SMTP_HOST=your.smtp.host
# SMTP_PORT=587
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password
# MAIL_FROM=Your Name <you@example.com>
EMAIL_PROVIDER=gmail
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Cornerstone <no-reply@cornerstone.local>

# AI chat (DashScope / Qwen via OpenAI-compatible API)
DASHSCOPE_API_KEY=
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
